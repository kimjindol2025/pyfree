class Animal:
    def __init__(self, name):
        self.name = name

    def speak(self):
        print("Animal says: " + self.name)

class Dog(Animal):
    def __init__(self, name, breed):
        super(Dog, self).__init__(name)
        self.breed = breed

    def speak(self):
        super(Dog, self).speak()
        print("Woof! I am " + self.breed)

dog = Dog("Buddy", "Labrador")
dog.speak()
