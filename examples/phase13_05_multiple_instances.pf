class Point:
    def __init__(self, x, y):
        self.x = x
        self.y = y

    def to_str(self):
        return "(" + str(self.x) + ", " + str(self.y) + ")"

p1 = Point(1, 2)
p2 = Point(3, 4)
print(p1.to_str())   # (1, 2)
print(p2.to_str())   # (3, 4)
print(p1.x)          # 1
print(p2.x)          # 3
