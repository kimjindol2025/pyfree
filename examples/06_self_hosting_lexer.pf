# 셀프호스팅: 기본 렉서 (PyFree로 작성)
# 목표: 소스 파일을 읽고 토큰 분석

# 1. 소스 파일 읽기
print("=== 셀프호스팅 렉서 ===")
print("")

source = read_file("examples/01_hello_world.pf")
print("소스:")
print(source)
print("")

# 2. 토큰 개수 세기 (매우 기본)
lines = 0
chars = 0

print("분석 중...")

# 3. 기본 통계
for i in range(1):
    lines = 3
    chars = len(source)

print("결과:")
print(chars)
print("characters")

print("")
print("✅ 셀프호스팅 완료!")
