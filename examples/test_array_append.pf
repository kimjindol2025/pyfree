# array_create + array_append 테스트

def array_create():
    """동적 배열 생성"""
    return {"_data": {}, "_len": 0}

def array_append(arr, value):
    """배열에 요소 추가"""
    arr["_data"][str(arr["_len"])] = value
    arr["_len"] = arr["_len"] + 1
    return arr

def array_len(arr):
    """배열 길이"""
    return arr["_len"]

def main():
    print("=== array_append 테스트 ===")

    arr = array_create()
    print("빈 배열 생성")
    print("길이: " + str(array_len(arr)))
    print()

    print("array_append(arr, 'hello') 실행")
    array_append(arr, "hello")
    print("길이: " + str(array_len(arr)))
    print()

    print("array_append(arr, 'world') 실행")
    array_append(arr, "world")
    print("길이: " + str(array_len(arr)))
    print()

    print("완료")

main()
