# tokens.pf - 간단한 토큰 정의

class Token:
    def __init__(self, token_type, value, line, column):
        self.type = token_type
        self.value = value
        self.line = line
        self.column = column

    def __repr__(self):
        return "Token"

def is_keyword(word):
    keywords = ["def", "class", "if", "else", "return"]
    for kw in keywords:
        if word == kw:
            return True
    return False

def is_digit(ch):
    digits = "0123456789"
    for d in digits:
        if ch == d:
            return True
    return False

def is_alpha(ch):
    return (ch >= 'a' and ch <= 'z') or (ch >= 'A' and ch <= 'Z') or ch == "_"
