# ast_nodes.pf - 간단한 AST 노드

class Expr:
    def __init__(self, value):
        self.value = value

    def eval(self):
        return self.value

class BinOp:
    def __init__(self, left, op, right):
        self.left = left
        self.op = op
        self.right = right

    def eval(self):
        if self.op == "+":
            return self.left.eval() + self.right.eval()
        elif self.op == "*":
            return self.left.eval() * self.right.eval()
        return 0
