# Timing & Performance
# ============================================

def measure_time(func, args: list[any]) -> float:
    """함수 실행 시간 측정 (구현 제약)"""
    # 정확한 시간 측정은 런타임 지원 필요
    # 여기서는 프레임워크만 제공
    return 0.0


# ============================================
# Validation
# ============================================

def is_valid_integer(s: str) -> bool:
    """유효한 정수 문자열인지 확인"""
    if len(s) == 0:
        return False

    start = 0
    if s[0] == '-' or s[0] == '+':
        start = 1

    if start >= len(s):
        return False

    for i in range(start, len(s)):
        if s[i] < '0' or s[i] > '9':
            return False

    return True


def is_valid_float(s: str) -> bool:
    """유효한 부동소수점 문자열인지 확인"""
    if len(s) == 0:
        return False

    dot_count = 0
    start = 0

    if s[0] == '-' or s[0] == '+':
        start = 1

    if start >= len(s):
        return False

    for i in range(start, len(s)):
        if s[i] == '.':
            dot_count = dot_count + 1
            if dot_count > 1:
                return False
        elif s[i] < '0' or s[i] > '9':
            return False

    return True


# ============================================
# Range & Iteration
# ============================================

def create_range(start: int, stop: int, step: int = 1) -> list[int]:
    """범위 생성"""
    result = []
    if step == 0:
        return result

    if step > 0:
        i = start
        while i < stop:
            result.append(i)
            i = i + step
    else:
        i = start
        while i > stop:
            result.append(i)
            i = i + step

    return result


def zip_with_index(lst: list[any]) -> list[tuple[int, any]]:
    """인덱스와 함께 반환"""
    result = []
    for i in range(len(lst)):
        result.append((i, lst[i]))
    return result


# ============================================
# Math Utilities
# ============================================

def gcd(a: int, b: int) -> int:
    """최대공약수"""
    while b != 0:
        tmp = b
        b = a % b
        a = tmp
    return a


def lcm(a: int, b: int) -> int:
    """최소공배수"""
    return (a * b) // gcd(a, b)


def factorial(n: int) -> int:
    """팩토리얼"""
    if n <= 1:
        return 1
    return n * factorial(n - 1)


def fibonacci(n: int) -> int:
    """피보나치"""
    if n <= 1:
        return n
    return fibonacci(n - 1) + fibonacci(n - 2)


def is_prime(n: int) -> bool:
    """소수 판정"""
    if n < 2:
        return False

    if n == 2:
        return True

    if n % 2 == 0:
        return False

    i = 3
    while i * i <= n:
        if n % i == 0:
            return False
        i = i + 2

    return True
