# redis caching
class Redis:
  def __init__(self): self.data = {}
  def get(self, key): return self.data.get(key)
  def set(self, key, value): self.data[key] = value
  def delete(self, key): del self.data[key] if key in self.data else None
  def expire(self, key, seconds): pass
def create_client(options = None): return Redis()
export Redis, create_client
